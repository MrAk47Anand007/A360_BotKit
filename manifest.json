{
  "manifest_version": 3,
  "name": "A360 BotKit",
  "version": "2.1",
  "description": "Enhances Automation Anywhere A360 bot editing in Control Room with line updates, copy and patch tools, and autosave.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://*/*"],
      "js": ["content_scripts/content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content_scripts/page_bridge.js"],
      "matches": ["https://*/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "author": "Anand S Kale",
  "homepage_url": "https://mrak47anand007.github.io/A360_BotKit/"
}
